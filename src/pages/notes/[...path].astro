---
import BaseLayout from '@layouts/BaseLayout.astro';
import Sidebar from '@components/Sidebar.astro';
import Backlinks from '@components/Backlinks.astro';
import TagBadge from '@components/TagBadge.astro';
import TableOfContents from '@components/TableOfContents.astro';
import { getEntry } from 'astro:content';
import fs from 'fs';
import path from 'path';

const DATA_DIR = process.cwd() + '/src/content/.data';

export async function getStaticPaths() {
  const notesDir = process.cwd() + '/src/content/notes';
  const entries = [];

  function clean(s) {
    return s
      .replace(/\.md$/i, '')
      .replace(/[^\w\s\-\/㐀-䶿一-鿿぀-ゟ゠-ヿ가-힣]/gu, '')
      .replace(/\s+/g, '-')
      .replace(/[A-Z]/g, function(c) { return c.toLowerCase(); })
      .replace(/\.(?=\/|$)/g, '');
  }

  function scan(dir, prefix) {
    for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
      if (entry.name.startsWith('.')) continue;
      var fp = path.join(dir, entry.name);
      if (entry.isDirectory()) {
        scan(fp, (prefix || '') + entry.name + '/');
      } else if (entry.name.endsWith('.md')) {
        if (entry.name === 'index.md') continue;
        var raw = (prefix || '') + entry.name.replace(/\.md$/, '');
        var slug = clean(raw);
        entries.push({ params: { path: slug }, props: { slug } });
      }
    }
  }
  scan(notesDir, '');
  return entries;
}

const { slug } = Astro.props;
const entry = await getEntry('notes', slug);
const { Content, headings } = await entry.render();

let backlinks = [];
let tags = [];

try {
  const backlinksData = JSON.parse(fs.readFileSync(path.join(DATA_DIR, 'backlinks.json'), 'utf-8'));
  backlinks = backlinksData[slug] || [];

  const tagsData = JSON.parse(fs.readFileSync(path.join(DATA_DIR, 'tags.json'), 'utf-8'));
  const notePath = '/notes/' + slug.split('/').map(s => encodeURIComponent(s)).join('/');
  for (const [tag, info] of Object.entries(tagsData)) {
    if (info.notes.some(n => n.path === notePath)) {
      tags.push(tag);
    }
  }
} catch (e) {}

const title = slug.split('/').pop();
---

<BaseLayout title={title} description={`笔记: ${title}`}>
  <div class="note-page" id="note-page">
    <aside class="sidebar-left" id="sidebar-left">
      <div class="sidebar-header-bar">
        <span class="sidebar-label">目录</span>
        <button class="sidebar-toggle" id="toggle-left-inner" aria-label="收起侧栏">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M4.177 7.823l2.396-2.396a.25.25 0 01.354 0l.94.94a.25.25 0 01.058.263.25.25 0 01-.058.092L5.5 8.5l2.207 1.778a.25.25 0 010 .354l-.94.94a.25.25 0 01-.354 0l-2.396-2.396a.75.75 0 010-1.06v-.293z"/></svg>
        </button>
      </div>
      <Sidebar currentPath={slug} />
    </aside>

    <button class="float-toggle float-toggle-left" id="toggle-left" aria-label="切换侧栏">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M4.177 7.823l2.396-2.396a.25.25 0 01.354 0l.94.94a.25.25 0 01.058.263.25.25 0 01-.058.092L5.5 8.5l2.207 1.778a.25.25 0 010 .354l-.94.94a.25.25 0 01-.354 0l-2.396-2.396a.75.75 0 010-1.06v-.293z"/></svg>
    </button>

    <main class="note-content">
      <nav class="breadcrumb">
        <a href="/">首页</a>
        {slug.split('/').map((part, i, arr) => (
          <>
            <span class="breadcrumb-sep">/</span>
            {i < arr.length - 1 ? (
              <a href={`/notes/${arr.slice(0, i + 1).join('/')}`}>{part}</a>
            ) : (
              <span>{part}</span>
            )}
          </>
        ))}
      </nav>

      <article class="markdown-body" data-pagefind-body data-pagefind-meta={`title:${title}`}>
        <header class="note-header">
          <h1>{title}</h1>
          {tags.length > 0 && (
            <div class="note-tags">
              {tags.map(tag => <TagBadge tag={tag} href={`/tags/${tag}`} />)}
            </div>
          )}
        </header>

        <Content />
      </article>

      <Backlinks backlinks={backlinks} />
    </main>

    <button class="float-toggle float-toggle-right" id="toggle-right" aria-label="切换目录">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M11.823 7.823l-2.396-2.396a.25.25 0 00-.354 0l-.94.94a.25.25 0 00-.058.263.25.25 0 00.058.092L10.5 8.5l-2.207 1.778a.25.25 0 000 .354l.94.94a.25.25 0 00.354 0l2.396-2.396a.75.75 0 000-1.06v-.293z"/></svg>
    </button>

    <aside class="sidebar-right" id="sidebar-right">
      <div class="sidebar-header-bar">
        <span class="sidebar-label">本页目录</span>
        <button class="sidebar-toggle" id="toggle-right-inner" aria-label="收起目录">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M11.823 7.823l-2.396-2.396a.25.25 0 00-.354 0l-.94.94a.25.25 0 00-.058.263.25.25 0 00.058.092L10.5 8.5l-2.207 1.778a.25.25 0 000 .354l.94.94a.25.25 0 00.354 0l2.396-2.396a.75.75 0 000-1.06v-.293z"/></svg>
        </button>
      </div>
      <TableOfContents headings={headings} />
    </aside>
  </div>
</BaseLayout>

<script>
  (function() {
    const page = document.getElementById('note-page');
    const left = document.getElementById('sidebar-left');
    const right = document.getElementById('sidebar-right');
    function toggleSidebar(side) {
      page.classList.toggle('sidebar-' + side + '-collapsed');
      localStorage.setItem('sidebar-' + side,
        page.classList.contains('sidebar-' + side + '-collapsed') ? 'collapsed' : 'expanded');
    }

    // 左侧栏: 内按钮 + 浮动按钮 都绑定同一个切换
    const leftState = localStorage.getItem('sidebar-left');
    if (leftState === 'collapsed') page.classList.add('sidebar-left-collapsed');
    document.querySelectorAll('#toggle-left, #toggle-left-inner').forEach(btn => {
      if (btn) btn.addEventListener('click', () => toggleSidebar('left'));
    });

    // 右侧栏: 内按钮 + 浮动按钮
    const rightState = localStorage.getItem('sidebar-right');
    if (rightState === 'collapsed') page.classList.add('sidebar-right-collapsed');
    document.querySelectorAll('#toggle-right, #toggle-right-inner').forEach(btn => {
      if (btn) btn.addEventListener('click', () => toggleSidebar('right'));
    });
  })();
</script>

<style>
  .note-page {
    display: flex;
    max-width: 1400px;
    margin: 0 auto;
    min-height: calc(100vh - var(--header-height));
    position: relative;
  }
  /* 防止浮动按钮溢出被裁剪 */
  .note-page { overflow: visible; }

  .sidebar-header-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  .sidebar-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    font-weight: 600;
  }
  .sidebar-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border: none;
    border-radius: 4px;
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: background 0.1s, color 0.1s;
  }
  .sidebar-toggle:hover {
    background: var(--color-bg-tertiary);
    color: var(--color-text-primary);
  }

  .sidebar-left {
    width: var(--sidebar-width);
    padding: 20px;
    border-right: 1px solid var(--color-border);
    flex-shrink: 0;
    overflow-x: hidden;
    overflow-y: auto;
    transition: width 0.2s ease, padding 0.2s ease, opacity 0.2s ease;
  }
  .sidebar-left-collapsed .sidebar-left {
    width: 0;
    padding: 20px 0;
    opacity: 0;
    border-right-color: transparent;
    overflow: hidden;
  }

  .note-content {
    flex: 1;
    min-width: 0;
    padding: 32px 40px;
    max-width: 820px;
  }

  .sidebar-right {
    width: 220px;
    padding: 20px;
    border-left: 1px solid var(--color-border);
    flex-shrink: 0;
    overflow: hidden;
    transition: width 0.2s ease, padding 0.2s ease, opacity 0.2s ease;
  }
  .sidebar-right-collapsed .sidebar-right {
    width: 0;
    padding: 20px 0;
    opacity: 0;
    border-left-color: transparent;
    overflow: hidden;
  }

  /* 浮动切换按钮 — 始终可见 */
  .float-toggle {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 20px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-bg-primary);
    color: var(--color-text-secondary);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s, color 0.1s, background 0.1s;
  }
  .note-page:hover .float-toggle {
    opacity: 1;
  }
  .float-toggle:hover {
    background: var(--color-bg-tertiary);
    color: var(--color-link);
  }

  .float-toggle-left {
    left: var(--sidebar-width);
    margin-left: -10px;
    border-left: none;
    border-radius: 0 4px 4px 0;
  }
  .sidebar-left-collapsed .float-toggle-left {
    left: 0;
    border-left: 1px solid var(--color-border);
    border-radius: 0 4px 4px 0;
  }

  .float-toggle-right {
    right: 220px;
    margin-right: -10px;
    border-right: none;
    border-radius: 4px 0 0 4px;
  }
  .sidebar-right-collapsed .float-toggle-right {
    right: 0;
    border-right: 1px solid var(--color-border);
    border-radius: 4px 0 0 4px;
  }

  /* 展开时浮动按钮箭头朝内，折叠时箭头朝外 */
  .sidebar-left-collapsed .float-toggle-left svg {
    transform: scaleX(-1);
  }
  .sidebar-right-collapsed .float-toggle-right svg {
    transform: scaleX(-1);
  }
  .sidebar-left-collapsed .float-toggle-left,
  .sidebar-right-collapsed .float-toggle-right {
    opacity: 1;
  }

  .breadcrumb { font-size: 0.8rem; color: var(--color-text-secondary); margin-bottom: 16px; }
  .breadcrumb a { color: var(--color-text-secondary); }
  .breadcrumb-sep { margin: 0 6px; color: var(--color-border); }
  .note-header { margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--color-border); }
  .note-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; }

  @media (max-width: 1024px) { .sidebar-right { display: none; } }
  @media (max-width: 768px) { .sidebar-left { display: none; } }
</style>
