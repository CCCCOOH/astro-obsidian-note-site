---
import BaseLayout from '@layouts/BaseLayout.astro';
import Icons from '@components/Icons.astro';
import fs from 'fs';
import path from 'path';

const notesDir = process.cwd() + '/src/content/notes';

interface TreeNode {
  name: string;
  path?: string;
  noteCount: number;
  children: TreeNode[];
}

function buildTree(dir: string): TreeNode[] {
  const result: TreeNode[] = [];
  try {
    const entries = fs.readdirSync(dir, { withFileTypes: true }).sort((a, b) => {
      if (a.isDirectory() && !b.isDirectory()) return -1;
      if (!a.isDirectory() && b.isDirectory()) return 1;
      return a.name.localeCompare(b.name);
    });

    for (const entry of entries) {
      if (entry.name.startsWith('.')) continue;
      const fullPath = path.join(dir, entry.name);
      if (entry.isDirectory()) {
        const children = buildTree(fullPath);
        if (children.length > 0) {
          result.push({
            name: entry.name,
            noteCount: children.reduce((s, c) => s + c.noteCount, 0),
            children,
          });
        }
      } else if (entry.name.endsWith('.md')) {
        const name = entry.name.replace(/\.md$/, '');
        const relPath = path.relative(notesDir, fullPath).replace(/\.md$/, '');
        result.push({ name, path: `/notes/${relPath}`, noteCount: 1, children: [] });
      }
    }
  } catch (e) {}
  return result;
}

function renderTreeHTML(nodes: TreeNode[], depth: number): string {
  let html = '';
  for (const node of nodes) {
    const iconSvg = depth === 0
      ? '<svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M1.75 1A1.75 1.75 0 000 2.75v10.5C0 14.216.784 15 1.75 15h12.5A1.75 1.75 0 0016 13.25v-8.5A1.75 1.75 0 0014.25 3h-3.5a.25.25 0 01-.2-.09l-.9-1.2c-.33-.44-.85-.71-1.4-.71H1.75z"/></svg>'
      : '<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M1.75 1A1.75 1.75 0 000 2.75v10.5C0 14.216.784 15 1.75 15h12.5A1.75 1.75 0 0016 13.25v-8.5A1.75 1.75 0 0014.25 3H7.5a.25.25 0 01-.2-.1l-.9-1.2C6.07 1.26 5.55 1 5 1H1.75z"/></svg>';

    const noteIcon = '<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0;opacity:0.6"><path fill-rule="evenodd" d="M0 1.75A.75.75 0 01.75 1h4.253c1.227 0 2.317.59 3 1.501A3.744 3.744 0 0111.006 1h4.245a.75.75 0 01.75.75v10.5a.75.75 0 01-.75.75h-4.507a2.25 2.25 0 00-1.591.659l-.622.621a.75.75 0 01-1.06 0l-.622-.621A2.25 2.25 0 005.258 13H.75a.75.75 0 01-.75-.75V1.75z"/></svg>';

    if (node.children.length > 0) {
      html += `<li class="tree-node">
        <div class="tree-row">
          ${iconSvg}
          <span class="tree-folder-name">${escapeHtml(node.name)}</span>
          <span class="tree-count">${node.noteCount}</span>
        </div>
        <ul class="tree-view">
          ${renderTreeHTML(node.children, depth + 1)}
        </ul>
      </li>`;
    } else {
      html += `<li class="tree-node">
        <div class="tree-row">
          ${noteIcon}
          <a href="${escapeHtml(node.path!)}" class="tree-note-link">${escapeHtml(node.name)}</a>
        </div>
      </li>`;
    }
  }
  return html;
}

function escapeHtml(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

const tree = buildTree(notesDir);
const totalNotes = tree.reduce((s, n) => s + n.noteCount, 0);
const treeHTML = renderTreeHTML(tree, 0);
---

<BaseLayout title="分类" description="笔记分类">
  <div class="categories-page">
    <h1><Icons name="category" size={24} /> 全部分类</h1>
    <p class="page-subtitle">共 {totalNotes} 篇笔记</p>

    {tree.length === 0 && <p class="no-categories">暂无分类</p>}

    {tree.length > 0 && (
      <div class="tree-wrapper">
        <ul class="tree-view tree-root" set:html={treeHTML} />
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .categories-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
  .categories-page h1 {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 0.25rem;
  }
  .page-subtitle {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    margin-bottom: 1.25rem;
  }
  .no-categories {
    color: var(--color-text-secondary);
    text-align: center;
    padding: 3rem;
  }

  .tree-wrapper {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-primary);
    padding: 4px 0;
  }

  .tree-view {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tree-root { padding: 0; }

  .tree-view .tree-view {
    padding-left: 1.25rem;
    margin-left: 1rem;
    border-left: 1px solid var(--color-border);
  }

  .tree-node { margin: 0; }

  .tree-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    border-radius: 0;
    transition: background 0.1s;
    cursor: default;
  }
  .tree-row:hover { background: var(--color-bg-secondary); }

  .tree-folder-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .tree-note-link {
    font-size: 0.9rem;
    color: var(--color-link);
    text-decoration: none;
    flex: 1;
  }
  .tree-note-link:hover { text-decoration: underline; }

  .tree-count {
    margin-left: auto;
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    background: var(--color-bg-tertiary);
    padding: 1px 8px;
    border-radius: 10px;
    min-width: 22px;
    text-align: center;
    line-height: 1.5;
  }
</style>
