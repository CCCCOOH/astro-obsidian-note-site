---
// src/components/Sidebar.astro — 目录树侧栏（支持任意深度嵌套）
import fs from 'fs';
import path from 'path';

export interface TreeNode {
  name: string;
  path?: string;
  children?: TreeNode[];
}

export interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const notesDir = process.cwd() + '/src/content/notes';

function buildTree(dir: string, prefix: string = ''): TreeNode[] {
  const entries: TreeNode[] = [];
  try {
    const items = fs.readdirSync(dir, { withFileTypes: true });
    const sorted = items.sort((a, b) => {
      if (a.isDirectory() && !b.isDirectory()) return -1;
      if (!a.isDirectory() && b.isDirectory()) return 1;
      return a.name.localeCompare(b.name);
    });
    for (const entry of sorted) {
      if (entry.name.startsWith('.')) continue;
      const fullPath = path.join(dir, entry.name);
      const relPath = prefix + entry.name;
      if (entry.isDirectory()) {
        const children = buildTree(fullPath, `${relPath}/`);
        if (children.length > 0) {
          entries.push({ name: entry.name, children });
        }
      } else if (entry.name.endsWith('.md')) {
        const name = entry.name.replace(/\.md$/, '');
        entries.push({ name, path: '/notes/' + (prefix + name) });
      }
    }
  } catch (e) {}
  return entries;
}

function isChildActive(node: TreeNode, cp: string): boolean {
  if (node.path && sanitizeForMatch(node.path) === '/notes/' + cp) return true;
  if (node.children) return node.children.some(c => isChildActive(c, cp));
  return false;
}

// 清理路径中的特殊字符以匹配 Astro 内容集合 ID
function sanitizeForMatch(str: string): string {
  return str.replace(/[^\w\s\-./㐀-䶿一-鿿぀-ゟ゠-ヿ가-힣]/gu, '')
    .replace(/\s+/g, '-')
    .replace(/[A-Z]/g, c => c.toLowerCase())
    .replace(/\.(?=\/|$)/g, '');
}

function escapeHtml(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

// 递归渲染树节点（支持任意深度）
function renderTree(nodes: TreeNode[], cp: string): string {
  let html = '';
  for (const node of nodes) {
    if (node.path) {
      // 笔记文件节点 — 用清理后的路径比对 active 状态
      const active = sanitizeForMatch(node.path) === '/notes/' + cp;
      html += `<li class="tree-item">
        <a href="${escapeHtml(node.path)}" class="tree-link${active ? ' tree-active' : ''}">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="tree-icon"><path fill-rule="evenodd" d="M0 1.75A.75.75 0 01.75 1h4.253c1.227 0 2.317.59 3 1.501A3.744 3.744 0 0111.006 1h4.245a.75.75 0 01.75.75v10.5a.75.75 0 01-.75.75h-4.507a2.25 2.25 0 00-1.591.659l-.622.621a.75.75 0 01-1.06 0l-.622-.621A2.25 2.25 0 005.258 13H.75a.75.75 0 01-.75-.75V1.75z"/></svg>
          ${escapeHtml(node.name)}
        </a>
      </li>`;
    } else {
      // 目录节点
      const hasActive = isChildActive(node, cp);
      const childrenHtml = node.children && node.children.length > 0
        ? `<ul class="tree-sublist">${renderTree(node.children, cp)}</ul>`
        : '';
      html += `<li class="tree-item${hasActive ? ' tree-has-active' : ''}">
        <span class="tree-folder">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="tree-icon"><path fill-rule="evenodd" d="M1.75 1A1.75 1.75 0 000 2.75v10.5c0 .966.784 1.75 1.75 1.75h12.5A1.75 1.75 0 0016 13.25v-8.5A1.75 1.75 0 0014.25 3H7.5a.25.25 0 01-.2-.1l-.9-1.2C6.07 1.26 5.55 1 5 1H1.75zM12.5 5.5h-9V7h9V5.5zM3.5 8.5h9V10h-9V8.5zm0 3h5.5v-1.5H3.5v1.5z"/></svg>
          ${escapeHtml(node.name)}
        </span>
        ${childrenHtml}
      </li>`;
    }
  }
  return html;
}

const tree = buildTree(notesDir);
const treeHTML = renderTree(tree, currentPath);

// SVG 图标内联定义，供 set:html 中的元素通过 use 引用 — 但 use 需要 defs，不用了，直接内联 SVG
---

<nav class="sidebar-tree">
  <div class="sidebar-header">
    <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="tree-icon"><path fill-rule="evenodd" d="M1.75 1A1.75 1.75 0 000 2.75v10.5c0 .966.784 1.75 1.75 1.75h12.5A1.75 1.75 0 0016 13.25v-8.5A1.75 1.75 0 0014.25 3H7.5a.25.25 0 01-.2-.1l-.9-1.2C6.07 1.26 5.55 1 5 1H1.75zM12.5 5.5h-9V7h9V5.5zM3.5 8.5h9V10h-9V8.5zm0 3h5.5v-1.5H3.5v1.5z"/></svg>
    <span>笔记目录</span>
  </div>
  {tree.length > 0
    ? <ul class="tree-list" set:html={treeHTML} />
    : <p class="sidebar-empty">暂无笔记</p>
  }
</nav>

<style is:global>
  .sidebar-tree {
    font-size: 0.85rem;
  }
  .sidebar-header {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    margin-bottom: 12px;
    font-weight: 600;
  }
  .sidebar-empty {
    color: var(--color-text-secondary);
    text-align: center;
    padding: 2rem;
    font-size: 0.8rem;
  }

  .tree-list, .tree-sublist {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tree-sublist {
    padding-left: 16px;
    margin-left: 6px;
    margin-top: 2px;
    border-left: 1px solid var(--color-border);
  }
  .tree-item { margin: 1px 0; }

  .tree-link, .tree-folder {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 3px 8px;
    border-radius: 4px;
    color: var(--color-text-secondary);
    text-decoration: none;
    cursor: default;
  }
  .tree-link {
    cursor: pointer;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 0.82rem;
  }
  .tree-link:hover {
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
    text-decoration: none;
  }
  .tree-active {
    background: var(--color-bg-tertiary) !important;
    color: var(--color-link) !important;
    font-weight: 500;
  }
  .tree-folder {
    font-size: 0.78rem;
    font-weight: 500;
  }
  .tree-has-active > .tree-folder {
    color: var(--color-link);
  }

  .tree-icon {
    flex-shrink: 0;
    opacity: 0.7;
  }
  .tree-folder .tree-icon {
    opacity: 0.8;
  }
</style>
